#!/bin/sh /etc/rc.common
# WHU Campus Network Auto-Authentication Init Script
# Based on: https://github.com/cccht/auto-whu-openwrt
# Reference: https://www.miaoer.net/posts/network/whu-openwrt-authentication

START=99
STOP=10

USE_PROCD=1

PROG=/usr/bin/whu-auth
LOG_TAG="whu-auth"

whu_auth_get_config() {
    local enabled
    config_get enabled "$1" enabled "0"
    config_get username "$1" username ""
    config_get password "$1" password ""
    config_get domain "$1" domain ""
    config_get auth_server "$1" auth_server "https://portal.whu.edu.cn"
    config_get check_interval "$1" check_interval "60"
    config_get retry_count "$1" retry_count "3"
    config_get interface "$1" interface "wan"
}

start_service() {
    config_load whu-auth
    config_foreach whu_auth_get_config whu-auth

    if [ "$enabled" != "1" ]; then
        logger -t "$LOG_TAG" "WHU Auth is disabled"
        return
    fi

    if [ -z "$username" ] || [ -z "$password" ]; then
        logger -t "$LOG_TAG" "Username or password not configured"
        return
    fi

    logger -t "$LOG_TAG" "Starting WHU Auth daemon..."

    procd_open_instance
    procd_set_param command "$PROG"
    procd_append_param command --username "$username"
    procd_append_param command --password "$password"
    procd_append_param command --domain "$domain"
    procd_append_param command --server "$auth_server"
    procd_append_param command --interval "$check_interval"
    procd_append_param command --retry "$retry_count"
    procd_append_param command --interface "$interface"
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    logger -t "$LOG_TAG" "Stopping WHU Auth daemon..."
}

service_triggers() {
    procd_add_reload_trigger "whu-auth"
}
